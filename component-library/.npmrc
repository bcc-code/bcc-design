# Hoist Storybook and related deps so the preview iframe can resolve them (pnpm + Storybook)
public-hoist-pattern[]=*storybook*
public-hoist-pattern[]=*@storybook*
# Hoist BCC packages so they can be resolved when importing (e.g. in Storybook or consuming apps)
public-hoist-pattern[]=@bcc-code/icons-vue
public-hoist-pattern[]=@bcc-code/design-tokens
